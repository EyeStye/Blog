  "content": "<div style=\"color: rgb(252, 252, 250); background-color: rgb(45, 42, 46); font-family: Consolas, &quot;Courier New&quot;, monospace; font-size: 18px; line-height: 24px; white-space: pre;\"><div><span style=\"color: #939293;\">#</span><span style=\"color: #ff6188;\">include</span><span style=\"color: #ab9df2;\"> </span><span style=\"color: #939293;\">&lt;</span><span style=\"color: #ffd866;\">bits/stdc++.h</span><span style=\"color: #939293;\">&gt;</span></div><div><span style=\"color: #ff6188;\">using</span> <span style=\"color: #78dce8;font-style: italic;\">namespace</span> <span style=\"color: #78dce8;\">std</span><span style=\"color: #939293;\">;</span></div><br><div><span style=\"color: #78dce8;font-style: italic;\">struct</span> <span style=\"color: #78dce8;\">UF</span> <span style=\"color: #939293;\">{</span></div><div>&nbsp; <span style=\"color: #78dce8;\">vector</span><span style=\"color: #939293;\">&lt;</span><span style=\"color: #78dce8;font-style: italic;\">int</span><span style=\"color: #939293;\">&gt;</span> uf<span style=\"color: #939293;\">;</span></div><div>&nbsp; <span style=\"color: #a9dc76;\">UF</span><span style=\"color: #939293;\">(</span><span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #fc9867;font-style: italic;\">N</span><span style=\"color: #939293;\">)</span> <span style=\"color: #939293;\">:</span> <span style=\"color: #a9dc76;\">uf</span><span style=\"color: #939293;\">(</span>N<span style=\"color: #939293;\">,</span> <span style=\"color: #ff6188;\">-</span><span style=\"color: #ab9df2;\">1</span><span style=\"color: #939293;\">)</span> <span style=\"color: #939293;\">{}</span></div><div>&nbsp; <span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #a9dc76;\">find</span><span style=\"color: #939293;\">(</span><span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #fc9867;font-style: italic;\">v</span><span style=\"color: #939293;\">)</span> <span style=\"color: #939293;\">{</span></div><div>&nbsp; &nbsp; <span style=\"color: #ff6188;\">return</span> uf<span style=\"color: #939293;\">[</span>v<span style=\"color: #939293;\">]</span> <span style=\"color: #ff6188;\">&lt;</span> <span style=\"color: #ab9df2;\">0</span> <span style=\"color: #ff6188;\">?</span> v <span style=\"color: #ff6188;\">:</span> uf<span style=\"color: #939293;\">[</span>v<span style=\"color: #939293;\">]</span> <span style=\"color: #ff6188;\">=</span> <span style=\"color: #a9dc76;\">find</span><span style=\"color: #939293;\">(</span>uf<span style=\"color: #939293;\">[</span>v<span style=\"color: #939293;\">]);</span></div><div>&nbsp; <span style=\"color: #939293;\">}</span></div><div>&nbsp; <span style=\"color: #78dce8;font-style: italic;\">void</span> <span style=\"color: #a9dc76;\">unite</span><span style=\"color: #939293;\">(</span><span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #fc9867;font-style: italic;\">a</span><span style=\"color: #939293;\">,</span> <span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #fc9867;font-style: italic;\">b</span><span style=\"color: #939293;\">)</span> <span style=\"color: #939293;\">{</span></div><div>&nbsp; &nbsp; a <span style=\"color: #ff6188;\">=</span> <span style=\"color: #a9dc76;\">find</span><span style=\"color: #939293;\">(</span>a<span style=\"color: #939293;\">);</span></div><div>&nbsp; &nbsp; b <span style=\"color: #ff6188;\">=</span> <span style=\"color: #a9dc76;\">find</span><span style=\"color: #939293;\">(</span>b<span style=\"color: #939293;\">);</span></div><div>&nbsp; &nbsp; <span style=\"color: #ff6188;\">if</span> <span style=\"color: #939293;\">(</span>a <span style=\"color: #ff6188;\">==</span> b<span style=\"color: #939293;\">)</span></div><div>&nbsp; &nbsp; &nbsp; <span style=\"color: #ff6188;\">return</span><span style=\"color: #939293;\">;</span></div><div>&nbsp; &nbsp; <span style=\"color: #ff6188;\">if</span> <span style=\"color: #939293;\">(</span>uf<span style=\"color: #939293;\">[</span>a<span style=\"color: #939293;\">]</span> <span style=\"color: #ff6188;\">&gt;</span> uf<span style=\"color: #939293;\">[</span>b<span style=\"color: #939293;\">])</span> <span style=\"color: #939293;\">{</span></div><div>&nbsp; &nbsp; &nbsp; <span style=\"color: #a9dc76;\">swap</span><span style=\"color: #939293;\">(</span>a<span style=\"color: #939293;\">,</span> b<span style=\"color: #939293;\">);</span></div><div>&nbsp; &nbsp; <span style=\"color: #939293;\">}</span></div><div>&nbsp; &nbsp; uf<span style=\"color: #939293;\">[</span>a<span style=\"color: #939293;\">]</span> <span style=\"color: #ff6188;\">+=</span> uf<span style=\"color: #939293;\">[</span>b<span style=\"color: #939293;\">];</span></div><div>&nbsp; &nbsp; uf<span style=\"color: #939293;\">[</span>b<span style=\"color: #939293;\">]</span> <span style=\"color: #ff6188;\">=</span> a<span style=\"color: #939293;\">;</span></div><div>&nbsp; <span style=\"color: #939293;\">}</span></div><div>&nbsp; <span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #a9dc76;\">size</span><span style=\"color: #939293;\">(</span><span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #fc9867;font-style: italic;\">v</span><span style=\"color: #939293;\">)</span> <span style=\"color: #939293;\">{</span></div><div>&nbsp; &nbsp; <span style=\"color: #ff6188;\">return</span> <span style=\"color: #ff6188;\">-</span>uf<span style=\"color: #939293;\">[</span><span style=\"color: #a9dc76;\">find</span><span style=\"color: #939293;\">(</span>v<span style=\"color: #939293;\">)];</span> &nbsp;</div><div>&nbsp; <span style=\"color: #939293;\">}</span></div><div>&nbsp; <span style=\"color: #78dce8;font-style: italic;\">bool</span> <span style=\"color: #a9dc76;\">same</span><span style=\"color: #939293;\">(</span><span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #fc9867;font-style: italic;\">a</span><span style=\"color: #939293;\">,</span> <span style=\"color: #78dce8;font-style: italic;\">int</span> <span style=\"color: #fc9867;font-style: italic;\">b</span><span style=\"color: #939293;\">)</span> <span style=\"color: #939293;\">{</span></div><div>&nbsp; &nbsp; <span style=\"color: #ff6188;\">return</span> <span style=\"color: #a9dc76;\">find</span><span style=\"color: #939293;\">(</span>a<span style=\"color: #939293;\">)</span> <span style=\"color: #ff6188;\">==</span> <span style=\"color: #a9dc76;\">find</span><span style=\"color: #939293;\">(</span>b<span style=\"color: #939293;\">);</span></div><div>&nbsp; <span style=\"color: #939293;\">}</span></div><div><span style=\"color: #939293;\">};</span></div><br></div>"
